{
  "name": "dive-tools",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:aqua": "pnpm --filter aqua-fix dev",
    "dev:motion": "pnpm --filter motion-fix dev",
    "build": "pnpm --filter aqua-fix build && pnpm --filter motion-fix build && node scripts/assemble-dist.mjs",
    "build:aqua": "pnpm --filter aqua-fix build",
    "build:motion": "pnpm --filter motion-fix build",
    "preview": "vite preview --outDir dist",
    "predeploy": "pnpm build",
    "deploy": "gh-pages -d dist --nojekyll"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "vite": "^8.0.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp"]
  }
}
